# Auto detect text files and perform LF normalization
* text=auto

#
# The above will handle all files NOT listed below
#

# Salesforce metadata
*.cls text eol=lf
*.trigger text eol=lf
*.page text eol=lf
*.component text eol=lf
*.xml text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Documents
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Scripts
*.sh text eol=lf
*.py text eol=lf
